{
    "name": "@logosdx/tests",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "lint": "pnpm tsc --noEmit --project tsconfig.json",
        "tdd": "NODE_ENV=test vitest --watch --project=unit",
        "test": "NODE_ENV=test vitest run --project=unit",
        "test:coverage": "NODE_ENV=test vitest run --project=unit --coverage",
        "test:only": "NODE_ENV=test vitest run --project=unit",
        "test:ci": "NODE_ENV=test vitest run --project=unit --reporter=default --reporter=github-actions",
        "test:smoke": "NODE_ENV=test vitest run --project=browser",
        "memory": "tsx --expose-gc src/_memory-tests/index.ts",
        "memory:ui": "tsx src/_memory-tests/ui/server.ts"
    },
    "keywords": [],
    "homepage": "https://logosdx.dev/",
    "bugs": {
        "url": "https://github.com/logosdx/monorepo/issues",
        "email": "danilo@alonso.network"
    },
    "author": "Danilo Alonso <danilo@alonso.network>",
    "license": "BSD-3-Clause",
    "dependencies": {
        "@hapi/boom": "^10.0.1",
        "@hapi/hapi": "^21.4.0",
        "@hapi/hoek": "^11.0.7",
        "@logosdx/dom": "workspace:^",
        "@logosdx/fetch": "workspace:^",
        "@logosdx/hooks": "workspace:^",
        "@logosdx/localize": "workspace:^",
        "@logosdx/observer": "workspace:^",
        "@logosdx/react": "workspace:^",
        "@logosdx/state-machine": "workspace:^",
        "@logosdx/storage": "workspace:^",
        "@logosdx/utils": "workspace:^",
        "@types/chai": "^5.2.2",
        "@types/jsdom": "^27",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/sinon": "^21",
        "@vitest/browser-playwright": "^4.0.14",
        "@vitest/coverage-v8": "^4",
        "better-sse": "^0.16.1",
        "fast-check": "^4.1.1",
        "joi": "^18",
        "jsdom": "^28",
        "node-test-github-reporter": "^1.3.0",
        "playwright": "^1.58.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "sinon": "^21",
        "typescript": "5.9.3",
        "vitest": "^4"
    },
    "devDependencies": {
        "fake-indexeddb": "^6.2.5"
    }
}
