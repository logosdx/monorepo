{
  "name": "@logosdx/localize",
  "version": "2.0.0",
  "description": "A small, strongly-typed, full feature localization utility",
  "repository": {
    "type": "git",
    "url": "https://github.com/logosdx/monorepo",
    "directory": "packages/localize"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.mjs"
    },
    "./extractor": {
      "types": "./dist/types/extractor.d.ts",
      "require": "./dist/cjs/extractor.js",
      "import": "./dist/esm/extractor.mjs"
    }
  },
  "bin": {
    "logosdx-locale": "./dist/esm/cli.mjs"
  },
  "sideEffects": false,
  "watch": true,
  "browserNamespace": "LogosDx.Localize",
  "scripts": {
    "build": "zx ../../scripts/build.mjs",
    "lint": "pnpm tsc --noEmit --project tsconfig.json"
  },
  "files": [],
  "keywords": [
    "localization",
    "translation",
    "translate",
    "l10n",
    "i18n",
    "text tokens"
  ],
  "homepage": "https://logosdx.dev/",
  "bugs": {
    "url": "https://github.com/logosdx/monorepo/issues",
    "email": "danilo@alonso.network"
  },
  "author": "Danilo Alonso <danilo@alonso.network>",
  "license": "BSD-3-Clause",
  "dependencies": {
    "@logosdx/observer": "workspace:^",
    "@logosdx/utils": "workspace:^"
  }
}
