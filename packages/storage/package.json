{
  "name": "@logosdx/storage",
  "version": "2.0.0",
  "description": "Async key-value storage adapter with pluggable drivers",
  "repository": {
    "type": "git",
    "url": "https://github.com/logosdx/monorepo",
    "directory": "packages/storage"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.mjs"
    }
  },
  "sideEffects": false,
  "watch": true,
  "browserNamespace": "LogosDx.Storage",
  "scripts": {
    "build": "zx ../../scripts/build.mjs",
    "lint": "pnpm tsc --noEmit --project tsconfig.json"
  },
  "files": [],
  "keywords": [
    "storage",
    "key-value",
    "localStorage",
    "sessionStorage",
    "indexeddb",
    "async"
  ],
  "homepage": "https://logosdx.dev/",
  "bugs": {
    "url": "https://github.com/logosdx/monorepo/issues",
    "email": "danilo@alonso.network"
  },
  "author": "Danilo Alonso <danilo@alonso.network>",
  "license": "BSD-3-Clause",
  "dependencies": {
    "@logosdx/observer": "workspace:^",
    "@logosdx/utils": "workspace:^"
  }
}
